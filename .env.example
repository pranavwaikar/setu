# ⚡ Setu Environment Variables Example
# Copy this file to .env and configure the values for your self-hosted setup.

# ==========================================
# 🛑 REQUIRED CONFIGURATION
# Configure these variables before deploying.
# ==========================================

# The base domain used to derive tunnel subdomains (e.g., setu.yourdomain.com).
# Wildcard DNS must point subdomains here (e.g. *.setu.yourdomain.com).
TUNNEL_DOMAIN=setu.helios-logic.com

# The full public URL of your Setu instance dashboard (e.g., https://setu.yourdomain.com).
# Used for CORS and authentication callback checks.
PUBLIC_DOMAIN=https://setu.helios-logic.com

# A shared secret key used to authenticate CLI tunnel connections to the gateway.
# Make sure to set this to a secure, random string in production.
GATEWAY_API_TOKEN=default-gateway-secret

# Secret key used for signing JWT tokens for user authentication on the dashboard and API.
# Make sure to set this to a secure, random string in production.
JWT_SECRET=supersecretjwtkey

# Environment mode (development / production).
# Set to 'production' to enforce cookie security checks and reject fallback keys.
NODE_ENV=production


# ==========================================
# ⚙️ OPTIONAL / AUTOMATIC CONFIGURATION
# These are handled automatically by docker-compose, but can be overridden.
# ==========================================

# PostgreSQL database connection URL.
# If deploying using the compose postgres container, keep this default/empty.
DATABASE_URL=postgresql://postgres:password@postgres:5432/setu?schema=public

# Internal URL of the API service. Used by the dashboard to make server-side NestJS API calls.
# Automatically set to http://api:4000 in docker-compose.
INTERNAL_API_URL=http://localhost:4000

# Next.js build-time domain configurations.
# Automatically inherited from TUNNEL_DOMAIN and PUBLIC_DOMAIN during docker-compose build.
# Only define these if you are running the frontend locally in development mode (without Docker).
NEXT_PUBLIC_TUNNEL_DOMAIN=setu.helios-logic.com
NEXT_PUBLIC_PUBLIC_DOMAIN=https://setu.helios-logic.com

# Email configuration via Resend service (Optional, defaults to false)
# Enable this to require user email verification on signups and activate password reset.
ENABLE_EMAIL_VERFICATION=false
RESEND_API_KEY=re_xxxxxxxxx
# Optional: customize sender email address (Defaults to onboarding@resend.dev)
EMAIL_FROM=onboarding@resend.dev

# Admin panel credentials configuration
ADMIN_EMAIL=admin@setu.com
ADMIN_PASSWORD=adminpassword123
ADMIN_COOKIE_PASSWORD=sessionsecretcookiekey1234567890

# Dodo Payments configurations for Pro plan upgrades (Overlay Checkout)
DODO_API_KEY=dp_test_d8f28c29188e7bcf5f1a
DODO_TEST_MODE=true
# Optional Webhook Secret Key for verifying signatures (from Developer > Webhooks in Dodo)
DODO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

