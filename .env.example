# ⚡ Setu Environment Variables Example
# Copy this file to .env and configure the values for your self-hosted setup.

# ==========================================
# 🌐 Domain Configuration (Build-Time & Runtime)
# ==========================================

# The base domain used to derive tunnel subdomains (e.g., setu.yourdomain.com).
# Subdomains will be generated under this, e.g., my-app.setu.yourdomain.com
TUNNEL_DOMAIN=setu.helios-logic.com

# The full public URL of your Setu instance dashboard (e.g., https://setu.yourdomain.com).
PUBLIC_DOMAIN=https://setu.helios-logic.com


# ==========================================
# 🔑 Secrets & Authentication
# ==========================================

# A shared secret key used to authenticate CLI tunnel connections to the gateway.
# Make sure to set this to a secure, random string in production.
GATEWAY_API_TOKEN=default-gateway-secret

# Secret key used for signing JWT tokens for user authentication on the dashboard and API.
# Make sure to set this to a secure, random string in production.
JWT_SECRET=supersecretjwtkey


# ==========================================
# 🗄️ Database Configuration
# ==========================================

# PostgreSQL database URL used by the API service.
# If deploying via the bundled postgres service, you can keep the default.
DATABASE_URL=postgresql://postgres:password@postgres:5432/setu?schema=public
